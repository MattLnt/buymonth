generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  role        Role     @default(CLIENT)
  createdAt   DateTime @default(now())
  client      Client?
  resetTokens PasswordResetToken[]
}

model Client {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  societe          String
  contactNom       String?
  telephone        String?
  adresse          String?
  numeroTva        String?
  logoUrl          String?
  plan             String   @default("CLASSIC")
  stripeCustomerId String?
  stripeSubId      String?
  subStatus        String?
  subEndsAt        DateTime?
  trialEndsAt      DateTime?
  widgetsGratuits  Int      @default(0)
  biens            Bien[]
  widgetPayments   WidgetPayment[]
  createdAt        DateTime @default(now())
}

model Bien {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  titre       String
  description String?
  prixTotal   Int
  mensualite  Int
  type        String?
  chambres    Int?
  surface     Int?
  ville       String?
  province    String?
  adresse     String?
  images      String[]
  urlClient   String?
  published   Boolean  @default(true)
  vues        Int      @default(0)
  leads       Lead[]
  widgets     Widget[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Widget {
  id        String   @id @default(cuid())
  bienId    String
  bien      Bien     @relation(fields: [bienId], references: [id], onDelete: Cascade)
  type      String
  premium   Boolean  @default(false)
  vues      Int      @default(0)
  createdAt DateTime @default(now())
}

model WidgetPayment {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  bienId          String?
  montant         Int
  devise          String   @default("eur")
  statut          String   @default("paid")
  stripeSessionId String?
  createdAt       DateTime @default(now())
}

model Lead {
  id        String   @id @default(cuid())
  bienId    String?
  bien      Bien?    @relation(fields: [bienId], references: [id], onDelete: SetNull)
  nom       String?
  email     String?
  telephone String?
  revenu    Int?
  apport    Int?
  source    String
  createdAt DateTime @default(now())
}

model Settings {
  id           String   @id @default("default")
  apportPct    Float    @default(0.10)
  tauxAnnuel   Float    @default(0.0345)
  dureeMois    Int      @default(300)
  leadEmails   String[]
  essaiActif   Boolean  @default(false)
  essaiJours   Int      @default(14)
  blocageActif Boolean  @default(false)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}